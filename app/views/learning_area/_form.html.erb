<%= form_with model: @learning_module, url: { controller: 'learning_area', action: @learning_module.persisted? ? 'update' : 'create' }, multipart: true do |f| %>

    <div class="mb-3">
        <%= f.label :title, 'Title', class: 'form-label' %>
        <%= f.text_field :title,
          id: 'repository_title',
          placeholder: 'Title of the learning module…',
          class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :description, 'Description', class: 'form-label' %>
    <div class="form-text mb-1">
      You can input a <code>wiki.makerepo.com</code> link and the page will be displayed.
    </div>
    <%= f.trix_editor :description,
          placeholder: 'Description of the learning module…',
          class: 'form-control',
          id: 'redactor',
          'aria-label': 'Description' %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-sm-6">
      <%= f.label :training_id, 'Category', class: 'form-label' %>
      <%= f.select :training_id, @training_categories, {}, { class: 'form-select' } %>
    </div>
    <div class="col-sm-6">
      <%= f.label :level, 'Level', class: 'form-label' %>
      <%= f.select :level, @training_levels, {}, { class: 'form-select' } %>
    </div>
  </div>

  <div class="mb-3">
    <div class="form-check form-switch">
      <%= f.check_box :scorm, class: 'form-check-input', role: 'switch', id: 'scorm_toggle' %>
      <%= f.label :scorm, 'SCORM package', class: 'form-check-label' %>
    </div>
    <div class="form-text">Enable if uploading a SCORM <code>.zip</code> file instead of regular project files.</div>
  </div>

  <div id="regular-files-section">
    <div class="mb-3">
      <%= label_tag :file, 'Project Files', class: 'form-label' %>
      <%= file_field_tag 'files[]',
            type: :files,
            multiple: true,
            class: 'form-control',
            aria_label: 'Project Files' %>
      <div id="file-container"></div>
    </div>

    <div class="mb-3">
      <%= label_tag :photo, 'Gallery', class: 'form-label' %>
      <div class="input-group">
        <%= file_field_tag 'images[]',
              type: :files,
              multiple: true,
              class: 'form-control image-upload',
              aria_label: 'Select Pictures' %>
        <button class="btn btn-success" type="button" id="new-photo-input" aria-label="Add image input">
          <%= fa_icon 'plus' %>
        </button>
      </div>
    </div>

    <div id="dragndrop"
         class="border rounded-3 text-center py-4 mb-3"
         ondrop="dragndrop(event);"
         ondragover="dragover(event);">
      <%= fa_icon 'cloud-upload', class: 'fs-3' %>
      <p class="mb-0 mt-1 small">Drag &amp; Drop files here</p>
    </div>

    <div id="image-container" class="mb-3"></div>
  </div>

  <div id="scorm-section" class="mb-3" style="display: none;">
    <%= label_tag :scorm_file, 'SCORM Package (.zip)', class: 'form-label' %>
    <%= file_field_tag 'scorm_file',
          class: 'form-control',
          accept: '.zip',
          aria_label: 'SCORM zip file' %>
    <div class="form-text">Upload a valid SCORM <code>.zip</code> package.</div>
  </div>

  <div class="text-center border-top pt-4">
    <%= f.submit @learning_module.persisted? ? 'Save Changes' : 'Create Learning Module',
          class: 'btn btn-primary px-4',
          id: 'waiting-save-button' %>
    <p class="small mt-2 mb-0">
      This could take several minutes — do not refresh this page.
    </p>
    <span id="status-save"></span>
  </div>

<% end %>
