<% provide(:title, 'Learning Area') %>

<section class="card mb-3">
    <% if @learning_module.photos.any? %>
        <div class="bg-dark" style="height: 320px;">
            <%= image_tag @learning_module.photos.first,
                          alt: @learning_module.title,
                          class: 'card-img-top',
                          style: 'width: 100%; height: 320px; object-fit: cover;',
                          loading: 'lazy' %>
        </div>
    <% end %>

    <div class="card-body col-lg-8 mx-auto">
        <% if current_user.admin? %>
            <div class="d-flex justify-content-between mb-3">
                <%= link_to 'Edit', edit_learning_area_path(@learning_module.id), class: 'btn btn-sm btn-primary' %>
                <%= button_to 'Delete', learning_area_path(@learning_module.id), method: :delete,
                              class: 'btn btn-sm btn-danger',
                              data: { confirm: 'Are you sure? This will delete this learning module.' } %>
            </div>
        <% end %>

        <h1 class="fw-bold mb-1"><%= @learning_module.title %></h1>
        <p class="mb-3">
            <span class="badge rounded-pill border <%= return_border_color(@learning_module.level) %> <%= return_text_color(@learning_module.level) %>">
                <%= @learning_module.level %>
            </span>
            <span class="ms-2"><%= @learning_module.training.localized_name %></span>
        </p>

        <% if @learning_module_track.blank? %>
            <div class="d-flex align-items-center gap-3 border rounded-3 p-3 mb-3">
                <div class="flex-grow-1">
                    <p class="mb-0 fw-semibold">Ready to start?</p>
                    <p class="small mb-0">You haven't begun this module yet.</p>
                </div>
                <%= link_to 'Start Module',
                            start_learning_module_track_index_path(learning_module_id: @learning_module.id),
                            class: 'btn btn-primary btn-sm' %>
            </div>
        <% elsif @learning_module_track.first.status == 'In progress' %>
            <div class="d-flex align-items-center gap-3 border border-primary rounded-3 p-3 mb-3">
                <div class="flex-grow-1">
                    <p class="mb-0 fw-semibold">In Progress</p>
                    <p class="small mb-0">Mark this module as complete when you're done.</p>
                </div>
                <%= link_to 'Mark Completed',
                            completed_learning_module_track_index_path(learning_module_id: @learning_module.id),
                            class: 'btn btn-primary btn-sm' %>
            </div>
        <% elsif @learning_module_track.first.status == 'Completed' %>
            <div class="d-flex align-items-center gap-2 border border-success rounded-3 p-3 mb-3">
                <i class="fa fa-check-circle text-success fs-5"></i>
                <p class="mb-0">You've completed this module — great work!</p>
            </div>
        <% end %>

        <div class="mb-3">
            <%= sanitize @learning_module.description %>
        </div>

        <% if @learning_module.videos.any? %>
            <div class="mb-3">
                <%= video_tag url_for(@learning_module.videos.first),
                              controls: true,
                              controlslist: 'nodownload',
                              class: 'rounded border w-100',
                              style: 'max-height: 480px;' %>
            </div>
        <% end %>

        <%# Photo gallery — thumbnails, skipping first since it's the hero %>
        <% if @learning_module.photos.length > 1 %>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <% @learning_module.photos.each do |photo| %>
                    <div class="bg-dark rounded border" style="width: 80px; height: 80px;">
                        <%= image_tag photo,
                                      alt: 'Gallery photo',
                                      class: 'rounded',
                                      style: 'width: 80px; height: 80px; object-fit: cover; cursor: pointer;',
                                      loading: 'lazy' %>
                    </div>
                <% end %>
            </div>
        <% end %>

        <% if @learning_module.project_files.any? %>
            <div class="mb-3">
                <h6 class="mb-2">Project Files</h6>
                <ul class="list-group list-group-flush">
                    <% @learning_module.project_files.each do |file| %>
                        <li class="list-group-item d-flex align-items-center gap-2 px-0">
                            <i class="fa fa-file-o"></i>
                            <%= link_to file.filename.to_s, url_for(file) %>
                            <span class="small ms-auto"><%= (file.byte_size / 1000.0).round(1) %> KB</span>
                        </li>
                    <% end %>
                </ul>
            </div>
        <% end %>

    </div>

    <% if @valid_urls.present? %>
        <div class="border-top">
            <% @valid_urls.each do |url| %>
                <iframe width="100%" height="600px" src="<%= url %>" class="d-block border-0"></iframe>
            <% end %>
        </div>
    <% end %>

</section>

<%= render 'layouts/photoswipe' %>
