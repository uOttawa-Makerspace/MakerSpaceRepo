<%= form_with controller: :lockers, url: {action: :price}, method: :put, class: 'mb-3' do |f| %>
    <%= f.label 'shopifyProductLink', class: 'form-label' do %>
        Enter the shopify product link from the admin page here. This will attempt to extract the product ID from the URL and place it below.<br />
    <% end %>

    <%= f.text_field 'shopifyProductLink', class: 'form-control mb-2',
     placeholder: 'URL should look like https://admin.shopify.com/store/uottawa-makerspace/products/10478024917048' %>

    <div class="input-group">
        <span class="input-group-text">Extracted GID: gid://shopify/Product/</span>
        <%= f.text_field :value, class: 'w-auto flex-fill form-control-plaintext', readonly: true %>
        <%= f.submit class: 'btn btn-primary' %>
    </div>
    <div class="form-text">
        <span>Currently linked with <%= @locker_product_link ? tag.b(@locker_product_link) : 'nothing' %></span>
    </div>
<% end %>

<%#= debug @locker_product_info %>
<% if @locker_product_info %>
    <div class="card mb-3">
        <div class="row g-0">
            <div class="col-md-4">
                <%= image_tag @locker_product_info[:image], class: 'rounded-start object-fit-cover w-100 h-100', style: "max-height: 15em" %>
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h3 class="card-subtitle text-body-secondary"><%= @locker_product_info[:title] %></h3>
                    <h4 class="card-subtitle text-body-secondary">Main product</h4>
                    <p class="card-text">This is the product where product variants are chosen and assigned to a locker for checkout.</p>
                    <p class="card-text">
                        <b>Status</b> <code><%= @locker_product_info[:status] %></code> <br />
                        <b>Product ID</b> <code><%= @locker_product_info[:id] %></code> <br />
                        <b>Received pricing</b> <code><%= @locker_product_info[:price] %> CAD</code> <br />
                        <b>Variants attached</b> <code><%= @locker_product_info[:variants].count %></code>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h3 id="productVariants"><%= link_to '#', '#productVariants' %> Product variants</h3>

    <p>Locker sizes are product variants defined at Makerstore to indicate the price of the locker and display name
        Locker sizes defined on makerepo are used to track inventory and availability.
        Each are linked by the product variant's GID.
        <a href="#">Click here to go to the locker sync tool.</a></p>

    <% @locker_product_info[:variants].each do |gid, variant| %>
        <div class="card mb-3">
            <div class="row g-0">
                <div class="col-md-3" style="max-height: 15em">
                    <% if variant[:image] %>
                        <%= image_tag variant[:image], class: 'rounded-start object-fit-cover w-100 h-100' %>
                    <% else %>
                        <div class="bg-secondary-subtle w-100 h-100 rounded-start"></div>
                    <% end %>
                </div>
                <div class="col-md-9">
                    <div class="card-body">
                        <p class="card-text">
                            <b>Title</b> <%= variant[:title] %> <br />
                            <b>SKU</b> <code><%= variant[:sku] %></code> <br />
                            <b>Variant ID</b> <code><%= variant[:id] %></code> <br />
                            <b>Received pricing</b> <code><%= variant[:price] %> CAD</code>
                        </p>

                        <hr />

                        <% local = @local_lookup[gid] %>
                        <% if local %>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span>
                                    <b>Linked to:</b> <%= local.size %>
                                </span>
                                <button class="btn btn-sm btn-outline-danger">Unlink</button>
                                <button class="btn btn-sm btn-outline-secondary">Edit</button>
                            </div>
                        <% else %>
                            <%= button_to 'Create local size', locker_sizes_path,
                            params: { locker_size: { size: variant[:title], shopify_gid: gid } },
                                          class: 'btn btn-sm btn-outline-primary' %>
                        <% end %>
                    </div>
                </div>
            </div>
        </div>
    <% end %>

    <% unlinked = @locker_sizes.reject { |s| @makerstore_lookup.key?(s.shopify_gid) } %>
    <% if unlinked.any? %>
        <h4 class="mt-4">Unlinked Local Sizes</h4>
        <div class="list-group">
            <% unlinked.each do |size| %>
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><b><%= size.size %></b></span>
                        <button class="btn btn-sm btn-outline-secondary">Edit</button>
                    </div>
                    <%= form_with model: size, method: :patch do |f| %>
                        <div class="input-group">
                            <%= f.select :shopify_gid,
                                @locker_product_info[:variants].map { |_gid, v| [v[:displayName], v[:id], { 'data-data' => v.to_json }] },
                             { include_blank: 'Select variant...' },
                             { class: 'form-select form-select-sm' } %>
                            <%= f.submit 'Link', class: 'btn btn-sm btn-outline-primary' %>
                        </div>
                    <% end %>
                </div>
            <% end %>
        </div>
    <% end %>


    <%#= button_to 'Sync locker sizes', sync_sizes_preview_locker_sizes_url, class: 'btn btn-primary mb-3' %>

    <h3 id="lockerSizesSection"><%= link_to '#', '#lockerSizesSection' %> Locker Sizes</h3>
    <p>List of locker sizes available on Makerepo. This is what users request when filling out a locker rental request.
        Each locker size has a Makerstore product variant associated with it.</p>

    <table class="table table-hover">
        <thead class="table-primary">
            <tr>
                <th>Locker size</th>
                <th>Lockers associated</th>
                <th>SKU</th>
                <th>Shopify GID</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <%= LockerSize.find_each do |locker_size| %>
                <tr>
                    <td><%= locker_size.size %></td>
                    <td><%= locker_size.lockers.count %></td>
                    <td><%= %></td>
                    <td><code><%= locker_size.shopify_gid %></code></td>
                    <td><%= button_to fa_icon('trash'), locker_size_path(locker_size), method: :delete, 'aria-label' => 'Delete',
                                      data: {confirm: "Are you sure you want to delete this locker size?"}, class: 'btn btn-danger' %></td>
                </tr>
            <% end %>
        </tbody>
    </table>

    <%= form_with model: LockerSize.new do |f| %>
        <h4>Create a new locker size</h4>
        <p>Create a new locker size and link it to a store product variant.</p>
        <div class="input-group mb-3">
            <%= f.label :size, 'Locker dimensions', class: 'input-group-text' %>
            <%= f.text_field :size, placeholder: 'For example, 16x16', class: 'form-control' %>

            <%= f.label :shopify_gid, 'Select a product variant to use for checkout', class: 'input-group-text' %>
            <%= f.select :shopify_gid, @locker_product_info[:variants].map {|_gid, v| [ v[:displayName], v[:id], { 'data-data' => v.to_json} ] },
             {include_blank: 'Select variant...'},
             {class: 'form-select locker-variant-select'} %>
            <%= f.submit class: 'btn btn-success' %>
        </div>
    <% end %>

<% elsif @locker_product_link %>
    <p class="text-center text-danger fw-bold">
        Failed to load product information.
    </p>
<% else %>
    <p class="text-center">No valid link assigned...</p>
<% end %>
