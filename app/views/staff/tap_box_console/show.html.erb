<% content_for :title, "Tap Box Console" %>

<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h4 class="mb-0">
        <i class="fa fa-terminal me-2"></i>Tap Box Debugger Console
      </h4>
      <small class="text-muted">Real-time RFID tap event log &mdash; newest first</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <div id="connection-status" class="badge bg-secondary">
        Connecting&hellip;
      </div>
      <select id="filter-event-type" class="form-select form-select-sm" style="width: auto;">
        <option value="">All events</option>
        <option value="card_tap">Card Tap</option>
        <option value="sign_in">Sign In</option>
        <option value="sign_out">Sign Out</option>
        <option value="error">Error</option>
        <option value="warning">Warning</option>
        <option value="info">Info</option>
        <option value="membership_check">Membership Check</option>
      </select>
      <input
        type="text"
        id="filter-search"
        class="form-control form-control-sm"
        placeholder="Filter by card, user, message&hellip;"
        style="width: 220px;"
      >
      <button id="btn-clear-console" class="btn btn-sm btn-outline-secondary">
        Clear view
      </button>
    </div>
  </div>

  <div
    id="tap-box-console"
    style="
      background: #1e1e1e;
      color: #d4d4d4;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 12.5px;
      line-height: 1.6;
      height: calc(100vh - 160px);
      overflow-y: auto;
      border-radius: 6px;
      padding: 12px 16px;
      border: 1px solid #333;
    "
  >
    <table class="w-100" id="console-table" style="border-collapse: collapse;">
      <tbody id="console-body">
        <% @logs.reverse_each do |log| %>
          <%= render partial: "staff/tap_box_console/log_row", locals: { log: log } %>
        <% end %>
      </tbody>
    </table>

    <% if @logs.empty? %>
      <div id="empty-state" class="text-center py-5" style="color: #666;">
        <i class="fa fa-inbox fa-2x mb-2"></i>
        <p>No tap events yet. Waiting for card taps&hellip;</p>
      </div>
    <% end %>
  </div>
</div>

<style>
  #console-table tr {
    border-bottom: 1px solid #2a2a2a;
  }
  #console-table tr:hover {
    background: #2a2d30;
  }
  #console-table td {
    padding: 3px 10px 3px 0;
    vertical-align: top;
    white-space: nowrap;
  }
  #console-table td.msg-col {
    white-space: normal;
    word-break: break-word;
    width: 100%;
  }

  .log-badge {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    min-width: 70px;
    text-align: center;
  }
  .log-badge.card_tap         { background: #264f78; color: #6cb6ff; }
  .log-badge.sign_in          { background: #1a4731; color: #3fb950; }
  .log-badge.sign_out         { background: #3b2e1a; color: #d29922; }
  .log-badge.error            { background: #4a1a1a; color: #f85149; }
  .log-badge.warning          { background: #3b2e1a; color: #d29922; }
  .log-badge.info             { background: #1a3a4a; color: #58a6ff; }
  .log-badge.membership_check { background: #2d1a4a; color: #bc8cff; }

  .log-detail-key   { color: #808080; }
  .log-detail-value { color: #ce9178; }
  .log-card         { color: #dcdcaa; }
  .log-user         { color: #4ec9b0; }
  .log-space        { color: #c586c0; }
  .log-timestamp    { color: #666; }

  .console-new-row {
    animation: flash-in 0.6s ease-out;
  }
  @keyframes flash-in {
    0%   { background: #264f78; }
    100% { background: transparent; }
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const consoleEl    = document.getElementById("tap-box-console");
  const consoleBody  = document.getElementById("console-body");
  const emptyState   = document.getElementById("empty-state");
  const statusBadge  = document.getElementById("connection-status");
  const filterType   = document.getElementById("filter-event-type");
  const filterSearch = document.getElementById("filter-search");
  const btnClear     = document.getElementById("btn-clear-console");

  // Auto-scroll to bottom on load
  consoleEl.scrollTop = consoleEl.scrollHeight;

  // ActionCable subscription
  let subscription;
  if (typeof App !== "undefined" && App.cable) {
    subscription = App.cable.subscriptions.create("TapBoxConsoleChannel", {
      connected: function() {
        statusBadge.className = "badge bg-success";
        statusBadge.textContent = "● Connected";
      },
      disconnected: function() {
        statusBadge.className = "badge bg-danger";
        statusBadge.textContent = "● Disconnected";
      },
      rejected: function() {
        statusBadge.className = "badge bg-danger";
        statusBadge.textContent = "● Rejected";
      },
      received: function(data) {
        appendLogRow(data);
      }
    });
  } else {
    statusBadge.className = "badge bg-warning";
    statusBadge.textContent = "Cable unavailable";
  }

  function appendLogRow(data) {
    if (emptyState) emptyState.remove();

    const tr = document.createElement("tr");
    tr.className = "console-new-row";
    tr.dataset.eventType = data.event_type;
    tr.dataset.searchable = [
      data.card_number, data.user_name, data.message,
      data.space_name, data.mac_address,
      data.details ? JSON.stringify(data.details) : ""
    ].join(" ").toLowerCase();

    let detailsHtml = "";
    if (data.details && Object.keys(data.details).length > 0) {
      const parts = [];
      for (const [k, v] of Object.entries(data.details)) {
        const val = typeof v === "object" ? JSON.stringify(v) : v;
        parts.push('<span class="log-detail-key">' + escHtml(k) + '=</span><span class="log-detail-value">' + escHtml(String(val)) + '</span>');
      }
      detailsHtml = ' <span style="color:#555">|</span> ' + parts.join(" ");
    }

    tr.innerHTML =
      '<td class="log-timestamp">' + escHtml(data.created_at) + '</td>' +
      '<td><span class="log-badge ' + escHtml(data.event_type) + '">' + escHtml(data.event_type.replace("_", " ")) + '</span></td>' +
      '<td class="log-card">' + escHtml(data.card_number || "—") + '</td>' +
      '<td class="log-user">' + (data.user_name ? escHtml(data.user_name) : '<span style="color:#555">—</span>') + '</td>' +
      '<td class="log-space">' + (data.space_name ? escHtml(data.space_name) : '<span style="color:#555">—</span>') + '</td>' +
      '<td class="msg-col">' + escHtml(data.message) + detailsHtml + '</td>';

    consoleBody.appendChild(tr);
    applyFilters();

    // Auto-scroll if near bottom
    const isNearBottom = consoleEl.scrollHeight - consoleEl.scrollTop - consoleEl.clientHeight < 100;
    if (isNearBottom) {
      consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    // Cap at 1000 rows in DOM
    while (consoleBody.children.length > 1000) {
      consoleBody.removeChild(consoleBody.firstElementChild);
    }
  }

  function applyFilters() {
    const typeVal   = filterType.value;
    const searchVal = filterSearch.value.toLowerCase().trim();

    consoleBody.querySelectorAll("tr").forEach(function(row) {
      let visible = true;
      if (typeVal && row.dataset.eventType !== typeVal) visible = false;
      if (searchVal && row.dataset.searchable && !row.dataset.searchable.includes(searchVal)) visible = false;
      row.style.display = visible ? "" : "none";
    });
  }

  filterType.addEventListener("change", applyFilters);
  filterSearch.addEventListener("input", applyFilters);

  btnClear.addEventListener("click", function() {
    consoleBody.innerHTML = "";
  });

  function escHtml(str) {
    const div = document.createElement("div");
    div.textContent = str || "";
    return div.innerHTML;
  }
});
</script>