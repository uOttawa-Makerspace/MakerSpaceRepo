<%
  details_html = ""
  if log.details.present?
    parts = log.details.map do |k, v|
      val = v.is_a?(Hash) || v.is_a?(Array) ? v.to_json : v.to_s
      "<span class='log-detail-key'>#{h k}=</span><span class='log-detail-value'>#{h val}</span>"
    end
    details_html = " <span style='color:#555'>|</span> #{parts.join(' ')}".html_safe
  end

  # Format details safely for the data attribute to prevent quote collision
  search_details = log.details&.map { |k, v| "#{k} #{v}" }&.join(' ')
  search_string = [log.card_number, log.user&.name, log.message, log.space&.name, log.mac_address, search_details].compact.join(' ').downcase
%>

<tr
  class="<%= 'console-new-row' if local_assigns[:streamed] %>"
  data-event-type="<%= log.event_type %>"
  data-searchable="<%= CGI.escapeHTML(search_string) %>"
>
  <td class="log-timestamp"><%= log.created_at.strftime("%Y-%m-%d %H:%M:%S.%L") %></td>
  <td class="log-badge-col"><span class="log-badge <%= log.event_type %>"><%= log.event_type.tr("_", " ") %></span></td>
  <td class="log-card"><%= log.card_number || "—" %></td>
  <td class="log-user">
    <% if log.user %>
      <%= log.user.name %>
    <% else %>
      <span style="color:#555">—</span>
    <% end %>
  </td>
  <td class="log-space">
    <% if log.space %>
      <%= log.space.name %>
    <% else %>
      <span style="color:#555">—</span>
    <% end %>
  </td>
  <td class="msg-col"><%= h log.message %><%= details_html %></td>
</tr>